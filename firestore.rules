rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Global Catch-All Security Safeguard
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helper Functions and Primitives ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && (
        request.auth.token.email_verified == true || 
        request.auth.token.email == "ramdasraut9@gmail.com"
      );
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Role-based lookup from verified User document database
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function getUserRole() {
      return getUserData().role;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "ramdasraut9@gmail.com" || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserRole() == "Admin")
      );
    }

    function isTeamMember() {
      return isSignedIn() && (
        isAdmin() || 
        exists(/databases/$(database)/documents/users/$(request.auth.uid))
      );
    }

    // --- Entity-Specific Validation Helpers ---

    function isValidUser(data) {
      return data.keys().hasAll(['id', 'name', 'username', 'email', 'role', 'isActive'])
        && data.keys().size() == 6
        && data.id is string && data.id.size() <= 128
        && data.name is string && data.name.size() > 0 && data.name.size() <= 256
        && data.username is string && data.username.size() > 0 && data.username.size() <= 128
        && data.email is string && data.email.size() <= 256
        && data.role is string && data.role in ["Admin", "Sales", "CRM", "Finance", "SiteEngineer", "Procurement"]
        && data.isActive is bool;
    }

    function isValidLead(data) {
      return data.keys().hasAll(['id', 'name', 'email', 'phone', 'leadStatus', 'leadProject', 'ownerId', 'leadDate'])
        && data.id is string && data.id.size() <= 128
        && data.name is string && data.name.size() > 0 && data.name.size() <= 256
        && data.email is string && data.email.size() <= 256
        && data.phone is string && data.phone.size() <= 32
        && data.leadStatus is string && data.leadStatus.size() <= 64
        && data.leadProject is string && data.leadProject.size() <= 128
        && data.ownerId is string && data.ownerId.size() <= 128
        && data.leadDate is string && data.leadDate.size() <= 64;
    }

    function isValidProject(data) {
      return data.keys().hasAll(['id', 'name', 'companyName', 'location', 'reraNumber', 'projectType', 'projectStatus', 'description'])
        && data.id is string && data.id.size() <= 128
        && data.name is string && data.name.size() > 0 && data.name.size() <= 256
        && data.companyName is string && data.companyName.size() <= 256
        && data.reraNumber is string && data.reraNumber.size() <= 64;
    }

    function isValidVoucher(data) {
      return data.keys().hasAll(['id', 'voucherNumber', 'date', 'type', 'status', 'totalAmount'])
        && data.id is string && data.id.size() <= 128
        && data.voucherNumber is string && data.voucherNumber.size() <= 64
        && data.date is string && data.date.size() <= 64
        && data.type is string && data.type.size() <= 32
        && data.status is string && data.status.size() <= 32
        && data.totalAmount is number && data.totalAmount >= 0;
    }

    function isValidLedgerAccount(data) {
      return data.keys().hasAll(['id', 'name', 'code', 'group'])
        && data.id is string && data.id.size() <= 128
        && data.name is string && data.name.size() > 0 && data.name.size() <= 256
        && data.code is string && data.code.size() <= 64
        && data.group is string && data.group.size() <= 64;
    }

    function isValidAuditTrail(data) {
      return data.keys().hasAll(['id', 'userId', 'userName', 'action', 'module', 'timestamp'])
        && data.id is string && data.id.size() <= 128
        && data.userId is string && data.userId.size() <= 128
        && data.userName is string && data.userName.size() <= 256
        && data.action is string && data.action.size() <= 128
        && data.module is string && data.module.size() <= 64
        && data.timestamp is string && data.timestamp.size() <= 64;
    }

    // --- Collection Matches ---

    // 1. Users
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isTeamMember();
      allow create: if isSignedIn() && isValidId(userId) && isValidUser(incoming()) && (request.auth.uid == userId || isAdmin());
      allow update: if isSignedIn() && isValidId(userId) && isValidUser(incoming()) && (
        isAdmin() || 
        (request.auth.uid == userId && incoming().role == existing().role && incoming().isActive == existing().isActive)
      );
      allow delete: if isAdmin();
    }

    // 2. Leads
    match /leads/{leadId} {
      allow get: if isTeamMember();
      allow list: if isTeamMember() && (isAdmin() || resource.data.ownerId == request.auth.uid || getUserRole() in ["CRM", "Admin"]);
      allow create: if isTeamMember() && isValidId(leadId) && isValidLead(incoming());
      allow update: if isTeamMember() && isValidId(leadId) && isValidLead(incoming()) && (
        isAdmin() || 
        existing().ownerId == request.auth.uid || 
        getUserRole() in ["CRM", "Admin"]
      );
      allow delete: if isAdmin();
    }

    // 3. Projects
    match /projects/{projectId} {
      allow read: if isTeamMember();
      allow write: if isAdmin() && isValidId(projectId) && (request.method == "delete" || isValidProject(incoming()));
    }

    // 4. Vouchers
    match /vouchers/{voucherId} {
      allow read: if isTeamMember() && (isAdmin() || getUserRole() in ["Finance", "Admin"]);
      allow create: if isTeamMember() && isValidId(voucherId) && isValidVoucher(incoming()) && (getUserRole() in ["Finance", "Admin"]);
      allow update: if isTeamMember() && isValidId(voucherId) && isValidVoucher(incoming()) && (
        isAdmin() || (getUserRole() in ["Finance", "Admin"] && existing().status != "Approved")
      );
      allow delete: if isAdmin();
    }

    // 5. Ledger Accounts
    match /ledgerAccounts/{accountId} {
      allow read: if isTeamMember();
      allow write: if isAdmin() && isValidId(accountId) && (request.method == "delete" || isValidLedgerAccount(incoming()));
    }

    // 6. Audit Trails
    match /auditTrails/{trailId} {
      allow read: if isAdmin();
      allow create: if isSignedIn() && isValidId(trailId) && isValidAuditTrail(incoming());
      allow update, delete: if false; // Locked audit history
    }
  }
}
