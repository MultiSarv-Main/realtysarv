rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "ramdasraut9@gmail.com" ||
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "Admin"
      );
    }

    function isTeamMember() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isSameUser(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /companies/{companyId} {
      allow read, list: if isTeamMember();
      allow create, update, delete: if isAdmin();
    }

    match /users/{userId} {
      allow read, list: if isTeamMember();
      allow create: if isSignedIn() && (isSameUser(userId) || isAdmin());
      allow update: if isSignedIn() && (isSameUser(userId) || isAdmin());
      allow delete: if isAdmin();
    }

    match /projects/{projectId} {
      allow read, list: if isTeamMember();
      allow create, update, delete: if isAdmin();
    }

    match /leads/{leadId} {
      allow read, list: if isTeamMember();
      allow create, update, delete: if isTeamMember();
    }

    match /tasks/{taskId} {
      allow read, list: if isTeamMember();
      allow create, update, delete: if isTeamMember();
    }

    match /siteVisits/{visitId} {
      allow read, list: if isTeamMember();
      allow create, update, delete: if isTeamMember();
    }

    match /bookings/{bookingId} {
      allow read, list: if isTeamMember();
      allow create, update, delete: if isTeamMember();
    }

    match /vouchers/{voucherId} {
      allow read, list: if isTeamMember();
      allow create, update, delete: if isAdmin();
    }

    match /ledgerAccounts/{accountId} {
      allow read, list: if isTeamMember();
      allow create, update, delete: if isAdmin();
    }

    match /channelPartners/{partnerId} {
      allow read, list: if isTeamMember();
      allow create, update, delete: if isAdmin();
    }

    match /auditTrails/{trailId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    match /{document=**} {
      // Temporary development rule so the initial Firestore seed can be written.
      allow read, write: if true;
    }
  }
}
